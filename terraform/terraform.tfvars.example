# Copy to terraform.tfvars (gitignored) — do not commit secrets.
# oci iam compartment list -c <tenancy_ocid> --all

# Auth for Terraform (oracle/oci provider):
# - ApiKey: add to ~/.oci/config for your profile: user = "<IAM user OCID>", fingerprint, key_file = path to private PEM (Identity → Users → API keys).
# - SecurityToken: use `oci session authenticate --profile NAME` when it expires (browser).
# oci_provider_auth = "ApiKey"
# oci_config_profile     = "danbag"

tenancy_ocid     = "ocid1.tenancy.oc1..REPLACE"
compartment_ocid = "ocid1.compartment.oc1..REPLACE"
region           = "us-ashburn-1"

# Ubuntu 22.04 VM: emits oci_computeagent metrics when you have no other services (recommended for demos).
# create_linux_vm   = true
# ssh_public_key    = "ssh-rsa AAAA... comment"
# allowed_ssh_cidr  = "203.0.113.10/32"  # your public IP / office CIDR
#
# VM shape: prefer VM.Standard.E2.1.Micro (Always Free AMD). If the tenancy returns NotAuthorized
# or every AD returns Out of host capacity for VM.Standard.A1.Flex, switch shape or region and
# re-run terraform apply (see README “Linux VM”).
# vm_shape                  = "VM.Standard.E2.1.Micro"
# vm_ocpus                  = 1
# vm_memory_gb              = 1
# availability_domain_index = 0   # try 0,1, 2 if capacity errors in a region

# Prefix for resource names and OCIR path segment (default in variables.tf is splunk-oci-sample).
# resource_prefix = "acme-client-splunk-oci-dev"

# After docker push to OCIR (path must match ${resource_prefix}/metrics-bridge). Bump tag per build.
# Run a full `terraform apply` after changing this so Notifications → Function subscription keeps
# the new function OCID (avoid apply -target only the function).
# function_image = "iad.ocir.io/<namespace>/<resource_prefix>/metrics-bridge:0.1.8"

splunk_realm = "us1"

# Splunk Observability (metrics + OTLP traces)
splunk_access_token = "REPLACE_WITH_O11Y_ACCESS_TOKEN"

# Splunk Cloud HEC (logs)
splunk_hec_url    = "https://http-inputs-example.splunkcloud.com/services/collector/event"
splunk_hec_token  = "REPLACE_WITH_HEC_TOKEN"
splunk_hec_index  = "main"
splunk_hec_source = "oci:metrics-bridge"

# Optional: scan metrics from a different compartment than resource compartment
# metrics_compartment_ocid = "ocid1.compartment.oc1..REPLACE"

# Set true only when metrics compartment is the tenancy (root); required for root scans.
# metrics_list_in_subtree = true

# Periodic runs: Monitoring alarm → Notifications topic → Function (default: every 5 minutes).
# enable_periodic_invoke      = true
# schedule_interval_minutes   = 5
# tick_alarm_namespace        = "oci_internet_gateway"
# tick_alarm_query            = ""  # optional MQL override; default uses this stack’s Internet Gateway
